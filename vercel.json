{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "nodeVersion": "18.x",
        "includeFiles": [
          "dist/**",
          ".env",
          "package.json",
          "package-lock.json",
          "config/**",
          "database/**",
          "public/**",
          "src/**",
          "node_modules/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/admin",
      "dest": "/index.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/content-manager/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/content-type-builder/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "STRAPI_TELEMETRY_DISABLED": "true",
    "STRAPI_ADMIN_BACKEND_URL": "",
    "ADMIN_PATH": "/admin"
  }
}
