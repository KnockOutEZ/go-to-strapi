{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "nodejs18.x",
        "buildCommand": "npm install --legacy-peer-deps && npm run vercel-build",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/uploads/(.*)",
      "dest": "/dist/uploads/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/dist/admin/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/content-manager/(.*)",
      "dest": "/dist/content-manager/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/dist/index.js"
    },
    {
      "src": "/health",
      "dest": "/dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "STRAPI_TELEMETRY_DISABLED": "true",
    "STRAPI_ADMIN_BACKEND_URL": "",
    "ADMIN_PATH": "/admin"
  },
  "build": {
    "env": {
      "NODE_ENV": "production",
      "STRAPI_TELEMETRY_DISABLED": "true",
      "STRAPI_ADMIN_BACKEND_URL": "",
      "ADMIN_PATH": "/admin"
    }
  }
}
